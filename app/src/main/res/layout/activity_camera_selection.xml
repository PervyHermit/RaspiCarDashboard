<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:tag="root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:tag="primaryText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Camera kiezen"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:tag="secondaryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Selecteer de USB-camera en controleer direct de preview."
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <FrameLayout
        android:tag="panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:padding="8dp">

        <TextureView
            android:id="@+id/cameraSelectPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/cameraSelectStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/camera_overlay_bg"
            android:padding="12dp"
            android:text="Camera voorbereiden…"
            android:textColor="@color/text_primary" />
    </FrameLayout>

    <LinearLayout
        android:tag="panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:padding="14dp">

        <Spinner
            android:id="@+id/cameraSpinner"
            android:layout_width="match_parent"
            android:layout_height="52dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Switch
                android:id="@+id/cameraMirrorSwitch"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Spiegelbeeld"
                android:textColor="@color/text_primary" />

            <Spinner
                android:id="@+id/cameraRotationSpinner"
                android:layout_width="150dp"
                android:layout_height="56dp" />
        </LinearLayout>

        <Button
            android:id="@+id/saveCameraButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Camera opslaan" />
    </LinearLayout>
</LinearLayout>
