<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:tag="root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/dashboardContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerCard"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/timeText"
                    android:tag="primaryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:text="09:42"
                    android:textColor="@color/text_primary"
                    android:textSize="40sp" />

                <TextView
                    android:id="@+id/dateText"
                    android:tag="accentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="do 16 juli 2026"
                    android:textColor="@color/accent"
                    android:textSize="13sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="56dp"
                android:background="#294052" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/weatherIcon"
                    android:tag="primaryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☁"
                    android:textColor="@color/text_primary"
                    android:textSize="33sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/temperatureText"
                        android:tag="primaryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_waiting"
                        android:textColor="@color/text_primary"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/weatherDescription"
                        android:tag="secondaryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:text="Weer laden…"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dynamicCard"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:id="@+id/dynamicHeader"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/modeTitle"
                    android:tag="accentText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SPOTIFY"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/openWazeButton"
                    android:tag="action"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="9dp"
                    android:gravity="center"
                    android:minWidth="96dp"
                    android:paddingHorizontal="12dp"
                    android:text="Open Waze"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/speedText"
                    android:tag="accentCircle"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="0\nkm/u"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/contentSwitcher"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/mediaPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/albumArt"
                        android:tag="panelAlt"
                        android:layout_width="105dp"
                        android:layout_height="105dp"
                        android:contentDescription="Spotify albumhoes"
                        android:padding="10dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_launcher_foreground" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/trackTitle"
                            android:tag="primaryText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Spotify niet actief"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/artistText"
                            android:tag="secondaryText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Tik op Spotify om muziek te kiezen"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ProgressBar
                            android:id="@+id/mediaProgress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="12dp"
                            android:max="1000"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_bg" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_marginTop="9dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/previousButton"
                                android:tag="panelAlt"
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:gravity="center"
                                android:text="◀|"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/playPauseButton"
                                android:tag="accentCircle"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:layout_marginHorizontal="18dp"
                                android:gravity="center"
                                android:text="▶"
                                android:textColor="@color/text_primary"
                                android:textSize="24sp" />

                            <TextView
                                android:id="@+id/nextButton"
                                android:tag="panelAlt"
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:gravity="center"
                                android:text="|▶"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/cameraPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">

                    <TextureView
                        android:id="@+id/cameraPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <TextView
                        android:id="@+id/cameraStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/camera_overlay_bg"
                        android:padding="12dp"
                        android:text="Camera voorbereiden…"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/cameraMirrorButton"
                            android:tag="action"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:gravity="center"
                            android:text="Spiegel"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/backToMediaButton"
                            android:tag="action"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:gravity="center"
                            android:text="Spotify"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </FrameLayout>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/fixedAppsCard"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="122dp"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:padding="9dp">

            <TextView
                android:id="@+id/fixedSectionTitle"
                android:tag="accentText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BENODIGDE APPS"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/fixedAppsContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/shortcutsCard"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="116dp"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:padding="9dp">

            <TextView
                android:id="@+id/shortcutSectionTitle"
                android:tag="accentText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/custom_apps"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/customAppsContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal" />
        </LinearLayout>

        <TextView
            android:id="@+id/footerText"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:gravity="center_vertical"
            android:paddingStart="7dp"
            android:text="◉  LineageOS   •   Raspberry Pi 5   •   V3"
            android:textColor="#628097"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/trashTarget"
        android:layout_width="220dp"
        android:layout_height="70dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/trash_bg"
        android:gravity="center"
        android:text="🗑  Verwijderen"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />
</FrameLayout>
