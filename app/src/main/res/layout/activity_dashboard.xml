<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:tag="root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/dashboardContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerCard"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="82dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.15"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/timeText"
                    android:tag="primaryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:text="09:42"
                    android:textColor="@color/text_primary"
                    android:textSize="36sp" />

                <TextView
                    android:id="@+id/dateText"
                    android:tag="accentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="do 16 juli 2026"
                    android:textColor="@color/accent"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.15"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/weatherIcon"
                    android:tag="primaryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☁"
                    android:textColor="@color/text_primary"
                    android:textSize="30sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/temperatureText"
                        android:tag="primaryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_waiting"
                        android:textColor="@color/text_primary"
                        android:textSize="23sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/weatherDescription"
                        android:tag="secondaryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Weer laden…"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/speedText"
                android:tag="accentCircle"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="0&#10;km/u"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/volumeCard"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp">

            <TextView
                android:id="@+id/volumeIcon"
                android:tag="action"
                android:layout_width="42dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:text="🔊"
                android:textColor="@color/text_primary"
                android:textSize="17sp" />

            <SeekBar
                android:id="@+id/volumeSeek"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:max="15"
                android:progress="7" />

            <TextView
                android:id="@+id/volumePercentText"
                android:tag="secondaryText"
                android:layout_width="50dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="50%"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dynamicCard"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/modeTitle"
                android:tag="accentText"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:gravity="center_vertical"
                android:text="MUZIEK"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/contentSwitcher"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/mediaPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/albumArtControls"
                        android:layout_width="132dp"
                        android:layout_height="132dp">

                        <ImageView
                            android:id="@+id/albumArt"
                            android:tag="panelAlt"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Albumhoes"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_launcher_foreground" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_gravity="bottom"
                            android:background="#B0000000"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/previousButton"
                                android:layout_width="40dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="◀|"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/playPauseButton"
                                android:layout_width="48dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="▶"
                                android:textColor="@color/text_primary"
                                android:textSize="22sp" />

                            <TextView
                                android:id="@+id/nextButton"
                                android:layout_width="40dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="|▶"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/trackTitle"
                            android:tag="primaryText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="Geen muziek actief"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/artistText"
                            android:tag="secondaryText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Tik om muziek te kiezen"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ProgressBar
                            android:id="@+id/mediaProgress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="14dp"
                            android:max="1000"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_bg" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/cameraPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">

                    <TextureView
                        android:id="@+id/cameraPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <TextView
                        android:id="@+id/cameraStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/camera_overlay_bg"
                        android:padding="12dp"
                        android:text="Camera voorbereiden…"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="7dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/cameraMirrorButton"
                            android:tag="action"
                            android:layout_width="76dp"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="Spiegel"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/backToMediaButton"
                            android:tag="action"
                            android:layout_width="76dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="7dp"
                            android:gravity="center"
                            android:text="Media"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </FrameLayout>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/appsCard"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="164dp"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:padding="7dp">

            <LinearLayout
                android:id="@+id/fixedAppsContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal" />

            <LinearLayout
                android:id="@+id/customAppsContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/trashTarget"
        android:layout_width="220dp"
        android:layout_height="70dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/trash_bg"
        android:gravity="center"
        android:text="Verwijderen"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />
</FrameLayout>
