<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:tag="root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:tag="primaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RaspiCar instellingen"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:tag="secondaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="V4 • Spotify + lokale muziek • USB-camera • adaptieve layouts"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <Switch
            android:id="@+id/autoWazeSwitch"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="22dp"
            android:checked="true"
            android:paddingHorizontal="18dp"
            android:text="Waze één keer openen bij start dashboard"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />

        <Switch
            android:id="@+id/startGpsSwitch"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:checked="true"
            android:paddingHorizontal="18dp"
            android:text="Externe gps via GPS Connector gebruiken"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />

        <Switch
            android:id="@+id/weatherSwitch"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:checked="true"
            android:paddingHorizontal="18dp"
            android:text="Weer tonen via huidige GPS-locatie"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />

        <Switch
            android:id="@+id/externalReturnSwitch"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:checked="true"
            android:paddingHorizontal="18dp"
            android:text="Zwevende terugknop boven alle extern geopende apps"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />


        <TextView
            android:tag="accentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Muziek"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/mediaSourceSpinner"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/localMediaButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Lokale muziekmap en bibliotheek" />

        <TextView
            android:tag="accentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Camera"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/cameraSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Camera kiezen, spiegelen en roteren" />

        <TextView
            android:id="@+id/cameraSelectionText"
            android:tag="secondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />


        <Spinner
            android:id="@+id/cameraScaleSpinner"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/cameraAspectSpinner"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/cameraWidthLabel"
            android:tag="secondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Camerabreedte in paneel: 100%"
            android:textColor="@color/text_secondary" />

        <SeekBar
            android:id="@+id/cameraWidthSeek"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:max="55"
            android:progress="55" />

        <TextView
            android:tag="accentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Layout en kleur"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/layoutSpinner"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/themeSpinner"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <EditText
                android:id="@+id/customAccentInput"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:hint="#2A92FF"
                android:inputType="text"
                android:maxLength="7"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <Button
                android:id="@+id/applyAccentButton"
                android:layout_width="150dp"
                android:layout_height="52dp"
                android:text="Accent toepassen" />
        </LinearLayout>

        <TextView
            android:tag="accentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Scherm dimmen"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/dimModeSpinner"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/manualDimLabel"
            android:tag="secondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Handmatig dimniveau: 35%"
            android:textColor="@color/text_secondary" />

        <SeekBar
            android:id="@+id/manualDimSeek"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:max="80"
            android:progress="35" />

        <TextView
            android:id="@+id/dayDimLabel"
            android:tag="secondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Automatisch overdag: 0%"
            android:textColor="@color/text_secondary" />

        <SeekBar
            android:id="@+id/dayDimSeek"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:max="50"
            android:progress="0" />

        <TextView
            android:id="@+id/nightDimLabel"
            android:tag="secondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Automatisch ’s nachts: 45%"
            android:textColor="@color/text_secondary" />

        <SeekBar
            android:id="@+id/nightDimSeek"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:max="80"
            android:progress="45" />

        <TextView
            android:id="@+id/sunOffsetLabel"
            android:tag="secondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zonmoment verschuiven: 0 minuten"
            android:textColor="@color/text_secondary" />

        <SeekBar
            android:id="@+id/sunOffsetSeek"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:max="240"
            android:progress="120" />

        <Button
            android:id="@+id/overlayPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Overlaytoegang voor dimmer en terugknop" />

        <TextView
            android:tag="accentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Toegang en systeem"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/mediaPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Spotify-mediatoegang instellen" />

        <Button
            android:id="@+id/locationPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Locatietoegang instellen" />

        <Button
            android:id="@+id/cameraPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Cameratoegang instellen" />

        <Button
            android:id="@+id/homeSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Als standaard Home-app kiezen" />

        <Button
            android:id="@+id/androidSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Volledige Android-instellingen" />

        <Button
            android:id="@+id/testSplitButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Waze nu rechts openen" />

        <Button
            android:id="@+id/rerunSetupButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Setup opnieuw uitvoeren" />

        <TextView
            android:id="@+id/statusText"
            android:tag="panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:padding="16dp"
            android:text="Status"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
